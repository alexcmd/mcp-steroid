<idea-plugin>
    <id>com.jonnyzzz.mcp-steroid</id>
    <name>MCP Steroid</name>
    <vendor>jonnyzzz.com</vendor>

    <description><![CDATA[
    <p><strong>MCP Steroid</strong> brings the full power of the IntelliJ Platform to AI agents through the Model Context Protocol (MCP).</p>

    <p><b>IntelliJ platform works for AI agents as great as for human developers.</b></p>

    <p>MCP Steroid is an independent research project by Eugene Petrenko (<a href="https://jonnyzz.com">@jonnyzzz</a>). Not affiliated with, endorsed by, or supported by JetBrains s.r.o.</p>

    <h3>What You Get</h3>
    <ul>
        <li><b>9 MCP Tools:</b> Control IntelliJ IDEA programmatically - execute code, take screenshots, discover actions, debug, and more</li>
        <li><b>80+ MCP Resources:</b> Comprehensive guides covering LSP, IDE operations, debugger, tests, VCS, and more</li>
        <li><b>Vision Capabilities:</b> AI agents can see your IDE with screenshots and OCR (unique to MCP Steroid)</li>
        <li><b>Deep Integration:</b> Access PSI, inspections, refactorings, and full IntelliJ Platform API</li>
    </ul>

    <h3>Why MCP Steroid?</h3>
    <p>Unlike LSP-only solutions, MCP Steroid gives AI agents the same powerful IDE capabilities that developers use - semantic understanding, advanced refactorings, debugging, test running, and visual awareness.</p>

    <p><b>Compatible with all IntelliJ Platform-based IDEs:</b> IntelliJ IDEA, PyCharm, WebStorm, GoLand, CLion, Rider, and more.</p>

    <p><b>Requirements:</b> IntelliJ IDEA 2025.3 or newer (build 253 or later)</p>

    <br />
    <h3>Demo: CodeDozer & IntelliJ Debugger</h3>
    <iframe width="560" height="315" src="https://www.youtube.com/embed/8MjogrpfXLU" frameborder="0" allowfullscreen></iframe>
    <br /><br />

    <p>Visit <a href="https://mcp-steroid.jonnyzzz.com">https://mcp-steroid.jonnyzzz.com</a> for documentation and examples.</p>

    <p><small>IntelliJ IDEA, IntelliJ Platform, PyCharm, WebStorm, and JetBrains are trademarks of JetBrains s.r.o.</small></p>
    ]]></description>

    <depends>com.intellij.modules.platform</depends>

    <!--
      Optional integration with IntelliJ's bundled MCP Server plugin
      (com.intellij.mcpServer). When that plugin is loaded and enabled,
      mcpServer-integration.xml registers IntelliJMcpServerProbeImpl,
      which surfaces the IDE-bundled MCP server's endpoint on our pid
      marker so external monitors can discover both servers from one
      file. Plugin loads normally when the dependency is missing.
    -->
    <depends optional="true" config-file="mcpServer-integration.xml">com.intellij.mcpServer</depends>

    <extensionPoints>
        <!-- Extension point for screenshot metadata providers -->
        <extensionPoint
            name="screenshotMetadataProvider"
            interface="com.jonnyzzz.mcpSteroid.vision.ScreenshotMetadataProvider"
            dynamic="true"/>
    </extensionPoints>

    <!-- MCP tools, resources, and prompts are wired explicitly in McpToolRegistrations.kt -->
    <extensions defaultExtensionNs="com.jonnyzzz.mcp-steroid">

        <!-- Screenshot metadata providers -->
        <screenshotMetadataProvider implementation="com.jonnyzzz.mcpSteroid.vision.ScreenshotImageProvider"/>
        <screenshotMetadataProvider implementation="com.jonnyzzz.mcpSteroid.vision.SwingComponentTreeProvider"/>
        <screenshotMetadataProvider implementation="com.jonnyzzz.mcpSteroid.vision.OcrMetadataProvider"/>
    </extensions>

    <extensions defaultExtensionNs="com.intellij">
        <!-- MCP tool handlers, registered against their base interfaces. The interfaces live in
             :mcp-steroid-server (transport-agnostic); the IJ-specific implementations live here. -->
        <applicationService
            serviceInterface="com.jonnyzzz.mcpSteroid.server.ListProjectsToolHandler"
            serviceImplementation="com.jonnyzzz.mcpSteroid.server.ListProjectsToolHandlerIJ"/>
        <applicationService
            serviceInterface="com.jonnyzzz.mcpSteroid.server.ListWindowsToolHandler"
            serviceImplementation="com.jonnyzzz.mcpSteroid.server.ListWindowsToolHandlerIJ"/>
        <applicationService
            serviceInterface="com.jonnyzzz.mcpSteroid.server.ExecuteCodeToolHandler"
            serviceImplementation="com.jonnyzzz.mcpSteroid.server.ExecuteCodeToolHandlerIJ"/>
        <applicationService
            serviceInterface="com.jonnyzzz.mcpSteroid.server.ExecuteFeedbackToolHandler"
            serviceImplementation="com.jonnyzzz.mcpSteroid.server.ExecuteFeedbackToolHandlerIJ"/>
        <applicationService
            serviceInterface="com.jonnyzzz.mcpSteroid.server.VisionInputToolHandler"
            serviceImplementation="com.jonnyzzz.mcpSteroid.server.VisionInputToolHandlerIJ"/>
        <applicationService
            serviceInterface="com.jonnyzzz.mcpSteroid.server.VisionScreenshotToolHandler"
            serviceImplementation="com.jonnyzzz.mcpSteroid.server.VisionScreenshotToolHandlerIJ"/>
        <applicationService
            serviceInterface="com.jonnyzzz.mcpSteroid.server.OpenProjectToolHandler"
            serviceImplementation="com.jonnyzzz.mcpSteroid.server.OpenProjectToolHandlerIJ"/>
        <applicationService
            serviceInterface="com.jonnyzzz.mcpSteroid.server.PromptsContextHandler"
            serviceImplementation="com.jonnyzzz.mcpSteroid.server.PromptsContextHandlerIJ"/>

        <!-- Update checker notification group -->
        <notificationGroup id="jonnyzzz.mcp.steroid.updates"
                           displayType="BALLOON"/>

        <!-- Registry keys for configuration -->
        <registryKey key="mcp.steroid.execution.timeout" defaultValue="600"
            description="Script execution timeout in seconds"/>

        <registryKey key="mcp.steroid.dialog.killer.enabled" defaultValue="true"
            description="Automatically close modal dialogs before code execution"/>

        <registryKey key="mcp.steroid.server.port" defaultValue="6315"
            description="MCP server port (0 for auto-assign)"/>

        <registryKey key="mcp.steroid.server.host" defaultValue="127.0.0.1"
            description="MCP server bind address (use 0.0.0.0 for Docker access)"/>

        <!-- Demo Mode registry keys -->
        <registryKey key="mcp.steroid.demo.enabled" defaultValue="false"
            description="Enable Demo Mode overlay for MCP execution"/>
        <registryKey key="mcp.steroid.demo.minDisplayTime" defaultValue="3000"
            description="Minimum display time in milliseconds"/>
        <registryKey key="mcp.steroid.demo.maxLines" defaultValue="15"
            description="Maximum log lines to show in overlay"/>
        <registryKey key="mcp.steroid.demo.opacity" defaultValue="85"
            description="Background opacity (0-100)"/>
        <registryKey key="mcp.steroid.demo.focusFrame" defaultValue="true"
            description="Bring project frame to front when showing overlay"/>

        <!-- Update checker registry keys -->
        <registryKey key="mcp.steroid.updates.enabled" defaultValue="true"
            description="Enable automatic update checks"/>

        <!-- Storage folder configuration -->
        <registryKey key="mcp.steroid.storage.path" defaultValue=""
            description="Custom path for MCP execution storage. Empty (default) uses .idea/mcp-steroid/"/>
        <registryKey key="mcp.steroid.idea.description.enabled" defaultValue="true"
            description="Generate .idea/mcp-steroid.md description file in projects"/>

        <registryKey key="mcp.steroid.analytics.enabled" defaultValue="true"
            description="Toggles minimalistic analytics from the plugin"/>

        <!-- Kotlinc configuration -->
        <registryKey key="mcp.steroid.kotlinc.parameters" defaultValue="-language-version 2.2 -api-version 2.2"
            description="Additional kotlinc command-line parameters (space-separated). Default: -language-version 2.2 -api-version 2.2. For example: -Xskip-metadata-version-check"/>
        <registryKey key="mcp.steroid.kotlinc.home" defaultValue=""
            description="Path to external kotlinc home directory. When set, overrides the bundled kotlinc. Useful when the IDE ships a newer Kotlin version than the plugin bundles."/>

        <!-- Start MCP server when a project opens (writes URL files, runs analytics) -->
        <postStartupActivity
                implementation="com.jonnyzzz.mcpSteroid.server.SteroidsMcpServerStartupActivity"/>

        <!-- Silence the VCS Add/Remove confirmation dialogs that block agent flow.
             See VcsConfirmationSilencer KDoc for rationale and side-effects. -->
        <postStartupActivity
                implementation="com.jonnyzzz.mcpSteroid.execution.VcsConfirmationSilencer"/>
    </extensions>

    <!-- Start MCP server at IDE startup, before any project opens -->
    <applicationListeners>
        <listener class="com.jonnyzzz.mcpSteroid.server.SteroidsMcpServerAppLifecycleListener"
                  topic="com.intellij.ide.AppLifecycleListener"/>
    </applicationListeners>

</idea-plugin>
