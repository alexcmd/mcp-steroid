.hugo_build.lock

# Generated static files (version.json, updatePlugins.xml, install.sh, install.ps1, EULA, LICENSE) are
# written into build/generated-static — a `build/` dir, already ignored repo-wide. Hugo merges it via
# its `staticDir` list, so generated files never enter the tracked source tree and adding a new one
# needs no entry here.
