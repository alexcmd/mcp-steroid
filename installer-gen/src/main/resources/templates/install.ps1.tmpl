# devrig bootstrap installer (Windows) — https://mcp-steroid.jonnyzzz.com/install.ps1
#
#   irm https://mcp-steroid.jonnyzzz.com/install.ps1 | iex
#
# GENERATED by :installer-gen's InstallerGenerator from the resolved JDK model — DO NOT EDIT.
# Every URL + SHA-256 for every Windows platform is baked in below; no live discovery.
# Downloads devrig + a matching JDK 25, verifies SHA-256, unpacks verbatim under
# ~\.mcp-steroid\binaries\<artifact>-<os>-<cpu>-<version>-<sha12>\, writes launchers
# into ~\.mcp-steroid\bin\. All diagnostic output to stderr.

Set-StrictMode -Version Latest
$ErrorActionPreference = 'Stop'
[Net.ServicePointManager]::SecurityProtocol = [Net.SecurityProtocolType]::Tls12

$Version      = '@@VERSION@@'
$DevrigUrl    = '@@DEVRIG_URL@@'
$DevrigSha256 = '@@DEVRIG_SHA256@@'
$DevrigFormat = '@@DEVRIG_FORMAT@@'

# BAKED-IN per-platform JDK table (devrig coordinates are universal, set above).
$Platforms = @{
@@PLATFORM_TABLE_PS@@
}

function Write-Log([string]$m) { [Console]::Error.WriteLine("[mcp-steroid] $m") }
function Fail([string]$m) { Write-Log "ERROR: $m"; exit 1 }

# Home resolution: USERPROFILE -> HOME -> GetFolderPath (so pwsh-on-Linux tests can locate it too).
$InstallRoot = $env:USERPROFILE
if (-not $InstallRoot) { $InstallRoot = $env:HOME }
if (-not $InstallRoot) { $InstallRoot = [Environment]::GetFolderPath('UserProfile') }
if (-not $InstallRoot) { Fail 'cannot resolve user home (USERPROFILE/HOME/UserProfile all empty)' }

$SteroidHome = Join-Path $InstallRoot '.mcp-steroid'
$BinDir      = Join-Path $SteroidHome 'bin'
$BinariesDir = Join-Path $SteroidHome 'binaries'

# ── platform detection -> normalized <os>-<cpu> key ──
$cpu = $env:DEVRIG_CPU
if (-not $cpu) {
  switch ([System.Runtime.InteropServices.RuntimeInformation]::OSArchitecture) {
    'Arm64' { $cpu = 'arm64' }
    'X64'   { $cpu = 'x64' }
    default { Fail "unsupported CPU architecture" }
  }
}
$os = $env:DEVRIG_OS
if (-not $os) { $os = 'windows' }
$key = "$os-$cpu"
Write-Log "platform: $key"
if (-not $Platforms.ContainsKey($key)) { Fail "platform '$key' is not supported by this build" }
$p = $Platforms[$key]

New-Item -ItemType Directory -Force -Path $BinDir, $BinariesDir | Out-Null
# Sweep orphaned staging older than a day.
Get-ChildItem -Path $BinariesDir -Filter '.tmp.*' -ErrorAction SilentlyContinue |
  Where-Object { $_.LastWriteTime -lt (Get-Date).AddDays(-1) } |
  ForEach-Object { Remove-Item -Recurse -Force $_.FullName -ErrorAction SilentlyContinue }

function Install-Artifact([string]$kind, [string]$url, [string]$sha, [string]$fmt) {
  $sha12  = $sha.Substring(0, 12)
  $name   = "$kind-$key-$Version-$sha12"
  $target = Join-Path $BinariesDir $name
  if (Test-Path $target) { Write-Log "already installed: $name"; return $target }
  if ($fmt -ne 'zip') { Fail "unsupported archive format '$fmt' on Windows for $kind" }

  $pid_ = $PID
  $tmpZip    = Join-Path $BinariesDir ".tmp.$pid_.$kind.zip"
  $tmpUnpack = Join-Path $BinariesDir ".tmp.$pid_.$kind.unpack"
  Remove-Item -Recurse -Force $tmpZip, $tmpUnpack -ErrorAction SilentlyContinue

  Write-Log "downloading $kind ($url)..."
  Invoke-WebRequest -Uri $url -OutFile $tmpZip -UseBasicParsing
  $actual = (Get-FileHash -Algorithm SHA256 -Path $tmpZip).Hash.ToLowerInvariant()
  if ($actual -ne $sha) { Fail "SHA-256 mismatch for ${kind}: expected $sha, got $actual" }
  Write-Log "SHA-256 verified: $sha"

  New-Item -ItemType Directory -Force -Path $tmpUnpack | Out-Null
  Expand-Archive -Path $tmpZip -DestinationPath $tmpUnpack -Force
  if (Test-Path $target) {
    Write-Log "another install finished first; using existing tree"
    Remove-Item -Recurse -Force $tmpUnpack
  } else {
    Move-Item -Path $tmpUnpack -Destination $target
  }
  Remove-Item -Force $tmpZip -ErrorAction SilentlyContinue
  return $target
}

$devrigTarget = Install-Artifact 'devrig' $DevrigUrl $DevrigSha256 $DevrigFormat
$jdkTarget    = Install-Artifact 'jdk'    $p.JdkUrl  $p.JdkSha256  $p.JdkFormat

# ── locate launcher + JAVA_HOME ──
$launcher = Join-Path $devrigTarget $p.DevrigBinSub
if (-not (Test-Path $launcher)) { Fail "launcher not found at $launcher" }
if ($p.JdkJavaHome) { $jdkHome = Join-Path $jdkTarget $p.JdkJavaHome } else { $jdkHome = $jdkTarget }
if (-not (Test-Path (Join-Path $jdkHome 'bin\java.exe'))) {
  # pwsh-on-Linux test runs without java.exe; accept a bin/java stub there.
  if (-not (Test-Path (Join-Path $jdkHome 'bin/java'))) { Fail "java not found inside $jdkHome" }
}

# ── write launchers (paths relative to the install root) ──
$launcherRel = $launcher.Substring($InstallRoot.Length).TrimStart('\','/')
$jdkHomeRel  = $jdkHome.Substring($InstallRoot.Length).TrimStart('\','/')

# devrig.cmd — a SELF-CONTAINED batch launcher (no PowerShell at launch; PS is only this installer).
# Always pins the bundled JDK via DEVRIG_JAVA_HOME, then call's the bundled devrig.bat.
# Writes nothing to stdout (the MCP stdio channel): @echo off + set/call only.
$cmd = "@echo off`r`nset `"DEVRIG_JAVA_HOME=%USERPROFILE%\$jdkHomeRel`"`r`ncall `"%USERPROFILE%\$launcherRel`" %*`r`n"
Set-Content -Path (Join-Path $BinDir 'devrig.cmd') -Value $cmd -NoNewline:$false
Write-Log "launcher: $BinDir\devrig.cmd -> $launcherRel (DEVRIG_JAVA_HOME=$jdkHomeRel)"

# ── make devrig reachable on PATH: symlink devrig.cmd into a writable PATH dir under the profile ──
# Always create the symlink (we do not special-case $BinDir being on PATH). Never edit the
# registry/System PATH, never touch dirs outside the user home. The symlink targets the
# installation path and never clobbers a foreign devrig. (Symlink creation needs Developer
# Mode / admin; on failure we fall back to a PATH hint.)
$pathDirs = @($env:Path -split ';' | Where-Object { $_ })
$linked = $false
$cmdTarget = Join-Path $BinDir 'devrig.cmd'
foreach ($d in $pathDirs) {
  if ($d -eq $BinDir) { continue }                                              # never self-link
  if (-not $d.StartsWith($InstallRoot, [StringComparison]::OrdinalIgnoreCase)) { continue }
  if (-not (Test-Path -LiteralPath $d -PathType Container)) { continue }
  $linkPath = Join-Path $d 'devrig.cmd'
  $existing = Get-Item -LiteralPath $linkPath -ErrorAction SilentlyContinue
  if ($existing -and ($existing.LinkType -ne 'SymbolicLink' -or $existing.Target -ne $cmdTarget)) { continue }
  try {
    New-Item -ItemType SymbolicLink -Path $linkPath -Target $cmdTarget -Force -ErrorAction Stop | Out-Null
    Write-Log "linked $linkPath -> $cmdTarget"; $linked = $true; break
  } catch { continue }
}
if (-not $linked) {
  Write-Log ""
  Write-Log "could not symlink devrig into a PATH dir under your profile; add $BinDir to PATH manually."
  Write-Log ""
}

# ── done. We do NOT auto-register devrig with agents — that edits agent configs, so it is an
#    explicit user step. Just report that the binary is ready and how to register it. ──
Write-Log "devrig binary is ready: $BinDir\devrig.cmd"
Write-Log ""
Write-Log "To register devrig with your agents (Claude, Codex, Gemini), run:"
Write-Log "    devrig install"
